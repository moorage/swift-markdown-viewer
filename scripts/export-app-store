#!/bin/zsh

set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/lib/xcode-env.sh"

ensure_dirs
require_project

PLATFORM=""
ARCHIVE_PATH=""
EXPORT_OPTIONS_PLIST=""
ALLOW_PROVISIONING_UPDATES=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --platform)
      PLATFORM="${2:-}"
      shift 2
      ;;
    --archive-path)
      ARCHIVE_PATH="${2:-}"
      shift 2
      ;;
    --export-options-plist)
      EXPORT_OPTIONS_PLIST="${2:-}"
      shift 2
      ;;
    --allow-provisioning-updates)
      ALLOW_PROVISIONING_UPDATES=1
      shift 1
      ;;
    *)
      echo "usage: ./scripts/export-app-store --platform ios|macos --archive-path <path> --export-options-plist <path> [--allow-provisioning-updates]" >&2
      exit 1
      ;;
  esac
done

if [[ -z "${PLATFORM}" || -z "${ARCHIVE_PATH}" || -z "${EXPORT_OPTIONS_PLIST}" ]]; then
  echo "expected --platform, --archive-path, and --export-options-plist" >&2
  exit 1
fi

EXPORTS_DIR="${ARTIFACTS_DIR}/exports/${PLATFORM}"
rm -rf "${EXPORTS_DIR}"
mkdir -p "${EXPORTS_DIR}"

EXTRA_FLAGS=()
if [[ ${ALLOW_PROVISIONING_UPDATES} -eq 1 ]]; then
  EXTRA_FLAGS+=("-allowProvisioningUpdates")
  while IFS= read -r flag; do
    EXTRA_FLAGS+=("${flag}")
  done < <(xcode_auth_flags)
fi

xcodebuild \
  -exportArchive \
  -archivePath "${ARCHIVE_PATH}" \
  -exportPath "${EXPORTS_DIR}" \
  -exportOptionsPlist "${EXPORT_OPTIONS_PLIST}" \
  "${EXTRA_FLAGS[@]}"

echo "export created at ${EXPORTS_DIR}"
